# Segmentation + tracking (per well)
# ============================================================================

rule segment_and_track_per_well:
    input:
        manifest = EXPERIMENT_METADATA_DIR / "{experiment}" / "frame_contract.csv",
        validated = EXPERIMENT_METADATA_DIR / "{experiment}" / ".frame_contract.validated",
    output:
        out_csv = SEGMENTATION_DIR / "{experiment}" / "per_well" / "{well_id}" / "contracts" / "segmentation_tracking.csv",
        done = SEGMENTATION_DIR / "{experiment}" / "per_well" / "{well_id}" / "contracts" / ".segmentation_tracking.validated",
    params:
        device = lambda wc: str(config.get("segmentation_and_tracking", {}).get("device", "cuda")),
        pipeline_cfg = lambda wc: json.dumps(config),
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.segmentation_and_tracking.entrypoints.run_segmentation_and_tracking \
          --frame-manifest "{input.manifest}" \
          --experiment-id "{wildcards.experiment}" \
          --well-id "{wildcards.well_id}" \
          --output-root "{DATA_ROOT}" \
          --device "{params.device}" \
          --pipeline-cfg-json '{params.pipeline_cfg}'
        """


rule merge_segmentation_tracking:
    input:
        lambda wc: [
            str(SEGMENTATION_DIR / wc.experiment / "per_well" / w / "contracts" / "segmentation_tracking.csv")
            for w in wells_for_experiment(wc)
        ]
    output:
        merged = SEGMENTATION_DIR / "{experiment}" / "contracts" / "segmentation_tracking.csv",
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.segmentation_and_tracking.pipelines.merge_segmentation_and_tracking_contracts           --experiment "{wildcards.experiment}"           --output-root "{DATA_ROOT}"
        """


rule validate_segmentation_tracking:
    input:
        merged = SEGMENTATION_DIR / "{experiment}" / "contracts" / "segmentation_tracking.csv",
    output:
        done = SEGMENTATION_DIR / "{experiment}" / "contracts" / ".segmentation_tracking_merged.validated",
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" {PROJECT_ROOT}/src/data_pipeline/segmentation_and_tracking/pipelines/validate_segmentation_and_tracking.py           --input-csv "{input.merged}"           --output-flag "{output.done}"
        """

