"""
MorphSeq Pipeline - Snakemake Workflow

Contract-driven pipeline:
  - Extract physical scope metadata (scope-specific)
  - Build stitched FF images (scope-specific)
  - Build a single physical frame contract (source of truth)
  - Segment+track per well from the frame contract (GDINO + SAM2)
  - Process snips per well from segmentation_tracking only
"""

from pathlib import Path
import os
import json

# Configuration
# Path is relative to Snakefile location
configfile: str(Path(workflow.basedir) / "config.yaml")

# Get project root
WORKFLOW_DIR = Path(workflow.basedir)
PROJECT_ROOT = WORKFLOW_DIR.parent.parent.parent

# Pinned interpreter (per repo rules).
PYTHON = "/net/trapnell/vol1/home/mdcolon/software/miniconda3/envs/segmentation_grounded_sam/bin/python"

# Data root from config
DATA_ROOT = PROJECT_ROOT / config.get("data_root", "data_pipeline_output")
INPUTS_DIR = DATA_ROOT / "inputs"
PLATE_METADATA_DIR = INPUTS_DIR / "plate_metadata"
RAW_IMAGES_DIR = INPUTS_DIR / "raw_image_data"

# Output directories (within data_root)
EXPERIMENT_METADATA_DIR = DATA_ROOT / "experiment_metadata"
BUILT_IMAGE_DATA_DIR = DATA_ROOT / "built_image_data"
SEGMENTATION_DIR = DATA_ROOT / "segmentation_and_tracking"
PROCESSED_SNIPS_DIR = DATA_ROOT / "processed_snips"
AUXILIARY_MASKS_DIR = DATA_ROOT / "auxiliary_masks"
MODELS_DIR = DATA_ROOT / "models"
FEATURES_DIR = DATA_ROOT / "computed_features"
QUALITY_CONTROL_DIR = DATA_ROOT / "quality_control"
ANALYSIS_READY_DIR = DATA_ROOT / "analysis_ready"

# Experiment identifiers
EXPERIMENTS = config.get("experiments", ["20250912"])
MICROSCOPE = str(config.get("microscope", "YX1"))

print(f"Project root: {PROJECT_ROOT}")
print(f"Data root: {DATA_ROOT}")
print(f"Experiments: {EXPERIMENTS}")
print(f"Microscope: {MICROSCOPE}")

# Wildcard and identifier contract source:
# docs/refactors/streamline-snakemake/identifier_and_wildcard_contract.md
# Snakemake wildcards only capture path pieces; semantic validation stays in
# Python helpers and input functions.
# Smoke subsets (for example 20240418 -> A01,C01) come from config, not code.
ruleorder: generate_auxiliary_masks_well > aggregate_auxiliary_masks
ruleorder: segment_and_track_per_well > merge_segmentation_tracking
ruleorder: run_snip_processing_per_well > merge_snip_manifests

include: str(WORKFLOW_DIR / "rules" / "quality_control.smk")

def experiment_well_ids(experiment: str) -> list[str]:
    configured = config.get("experiment_wells") or {}
    wells = configured.get(str(experiment))
    if wells is None:
        wells = configured.get(experiment)
    if wells is None:
        for key, value in configured.items():
            if str(key) == str(experiment):
                wells = value
                break
    if wells:
        return [str(w) for w in wells]

    # When experiment_wells is absent from config, return [] so that discover_wells
    # derives wells from a freshly-rebuilt frame_contract.csv via the checkpoint path.
    # Do not read frame_contract.csv here — that file may be stale and would bypass
    # the checkpoint/source-of-truth flow.
    return []

