rule consolidate_qc:
    input:
        segmentation = QUALITY_CONTROL_DIR / "{experiment}" / "segmentation_qc" / "segmentation_qc_flags.csv",
        segmentation_done = QUALITY_CONTROL_DIR / "{experiment}" / "segmentation_qc" / "segmentation_qc_flags.csv.validated",
        viability = QUALITY_CONTROL_DIR / "{experiment}" / "viability_qc" / "viability_qc_flags.csv",
        viability_done = QUALITY_CONTROL_DIR / "{experiment}" / "viability_qc" / "viability_qc_flags.csv.validated",
        imaging = QUALITY_CONTROL_DIR / "{experiment}" / "auxiliary_mask_qc" / "auxiliary_mask_qc_flags.csv",
        imaging_done = QUALITY_CONTROL_DIR / "{experiment}" / "auxiliary_mask_qc" / "auxiliary_mask_qc_flags.csv.validated",
        focus = QUALITY_CONTROL_DIR / "{experiment}" / "focus_qc" / "focus_qc_flags.csv",
        focus_done = QUALITY_CONTROL_DIR / "{experiment}" / "focus_qc" / "focus_qc_flags.csv.validated",
        motion = QUALITY_CONTROL_DIR / "{experiment}" / "motion_qc" / "motion_qc_flags.csv",
        motion_done = QUALITY_CONTROL_DIR / "{experiment}" / "motion_qc" / "motion_qc_flags.csv.validated",
        death = QUALITY_CONTROL_DIR / "{experiment}" / "death_detection" / "death_detection_flags.csv",
        death_done = QUALITY_CONTROL_DIR / "{experiment}" / "death_detection" / "death_detection_flags.csv.validated",
        surface_area = QUALITY_CONTROL_DIR / "{experiment}" / "surface_area_qc" / "surface_area_qc_flags.csv",
        surface_area_done = QUALITY_CONTROL_DIR / "{experiment}" / "surface_area_qc" / "surface_area_qc_flags.csv.validated",
    output:
        csv = QUALITY_CONTROL_DIR / "{experiment}" / "consolidated" / "qc_flags.csv",
        done = QUALITY_CONTROL_DIR / "{experiment}" / "consolidated" / "qc_flags.csv.validated",
        schema = QUALITY_CONTROL_DIR / "{experiment}" / "consolidated" / "qc_flags.schema.json",
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" << 'EOF'
from pathlib import Path
import pandas as pd
import json
from data_pipeline.quality_control.consolidation.consolidate_qc import consolidate_qc_flags
from data_pipeline.schemas.quality_control import REQUIRED_COLUMNS_QC

segmentation = pd.read_csv(Path("{input.segmentation}"))
viability = pd.read_csv(Path("{input.viability}"))
imaging = pd.read_csv(Path("{input.imaging}"))
focus = pd.read_csv(Path("{input.focus}"))
motion = pd.read_csv(Path("{input.motion}"))
death = pd.read_csv(Path("{input.death}"))
surface_area = pd.read_csv(Path("{input.surface_area}"))

qc_df = consolidate_qc_flags(segmentation, viability, imaging, focus, motion, death, surface_area)
out = Path("{output.csv}")
out.parent.mkdir(parents=True, exist_ok=True)
qc_df.to_csv(out, index=False)
Path("{output.done}").write_text("ok\n")
Path("{output.schema}").write_text(json.dumps(dict(columns=REQUIRED_COLUMNS_QC), indent=2) + '\n')
EOF
        """

rule assemble_analysis_ready:
    input:
        consolidated_features = FEATURES_DIR / "{experiment}" / "consolidated" / "consolidated_snip_features.csv",
        consolidated_features_done = FEATURES_DIR / "{experiment}" / "consolidated" / "consolidated_snip_features.csv.validated",
        qc_flags = QUALITY_CONTROL_DIR / "{experiment}" / "consolidated" / "qc_flags.csv",
        qc_flags_done = QUALITY_CONTROL_DIR / "{experiment}" / "consolidated" / "qc_flags.csv.validated",
    output:
        csv = DATA_ROOT / "analysis_ready" / "{experiment}" / "analysis_ready.csv",
        done = DATA_ROOT / "analysis_ready" / "{experiment}" / ".analysis_ready.validated",
        schema = DATA_ROOT / "analysis_ready" / "{experiment}" / "analysis_ready.schema.json",
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" << 'EOF'
from pathlib import Path
import pandas as pd
import json
from data_pipeline.analysis_ready.assemble import assemble_analysis_ready, validate_analysis_ready_schema
from data_pipeline.schemas.analysis_ready import REQUIRED_COLUMNS_ANALYSIS_READY

features = pd.read_csv(Path("{input.consolidated_features}"))
qc = pd.read_csv(Path("{input.qc_flags}"))
analysis = assemble_analysis_ready(features, qc)
validate_analysis_ready_schema(analysis)
out = Path("{output.csv}")
out.parent.mkdir(parents=True, exist_ok=True)
analysis.to_csv(out, index=False)
Path("{output.done}").write_text("ok\n")
Path("{output.schema}").write_text(json.dumps(dict(columns=REQUIRED_COLUMNS_ANALYSIS_READY), indent=2) + '\n')
EOF
        """

# ============================================================================
# Workflow Targets
# ============================================================================

rule all:
    default_target: True
    """
    Default target: build the final analysis-ready outputs.
    """
    input:
        expand(
            DATA_ROOT / "analysis_ready" / "{exp}" / ".analysis_ready.validated",
            exp=EXPERIMENTS
        )
