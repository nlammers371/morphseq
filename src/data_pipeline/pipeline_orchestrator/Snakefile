    Default target: build the feature smoke outputs through consolidated features.
    """
    input:
        expand(
            FEATURES_DIR / "{exp}" / "consolidated" / "consolidated_snip_features.csv.validated",
            exp=EXPERIMENTS
        )
        + expand(
            FEATURES_DIR / "{exp}" / "stage_predictions" / "stage_predictions.csv.validated",
            exp=EXPERIMENTS
        )
        + expand(
            AUXILIARY_MASKS_DIR / "{exp}" / "contracts" / ".auxiliary_masks.validated",
            exp=EXPERIMENTS
        )
