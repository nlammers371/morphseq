rule stage_predictions_complete:
    """Run Phase 5 stage_predictions for all configured experiments (requires plate metadata)."""
    input:
        expand(DATA_ROOT / "computed_features" / "{exp}" / "contracts" / ".stage_predictions.validated", exp=EXPERIMENTS)
