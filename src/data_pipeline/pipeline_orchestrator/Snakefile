rule compute_stage_predictions:
    input:
        segmentation_tracking = SEGMENTATION_DIR / "{experiment}" / "contracts" / "segmentation_tracking.csv",
        segmentation_tracking_done = SEGMENTATION_DIR / "{experiment}" / "contracts" / ".segmentation_tracking_merged.validated",
        frame_contract = EXPERIMENT_METADATA_DIR / "{experiment}" / "frame_contract.csv",
        frame_contract_done = EXPERIMENT_METADATA_DIR / "{experiment}" / ".frame_contract.validated",
        plate_metadata = EXPERIMENT_METADATA_DIR / "{experiment}" / "plate_metadata.csv",
        plate_metadata_done = EXPERIMENT_METADATA_DIR / "{experiment}" / ".plate_metadata.validated",
    output:
        csv = FEATURES_DIR / "{experiment}" / "stage_predictions" / "stage_predictions.csv",
        done = FEATURES_DIR / "{experiment}" / "stage_predictions" / "stage_predictions.csv.validated",
    params:
        stage_cfg = lambda wc: json.dumps(config.get("feature_extraction", {}).get("stage_predictions", {})),
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.feature_extraction.entrypoints.compute_stage_predictions           --segmentation-tracking "{input.segmentation_tracking}"           --frame-contract "{input.frame_contract}"           --plate-metadata "{input.plate_metadata}"           --stage-cfg '{params.stage_cfg}'           --output-csv "{output.csv}"
        """


rule consolidate_features:
    input:
        segmentation_tracking = SEGMENTATION_DIR / "{experiment}" / "contracts" / "segmentation_tracking.csv",
        segmentation_tracking_done = SEGMENTATION_DIR / "{experiment}" / "contracts" / ".segmentation_tracking_merged.validated",
        frame_contract = EXPERIMENT_METADATA_DIR / "{experiment}" / "frame_contract.csv",
        frame_contract_done = EXPERIMENT_METADATA_DIR / "{experiment}" / ".frame_contract.validated",
        mask_geometry = FEATURES_DIR / "{experiment}" / "mask_geometry" / "mask_geometry_metrics.csv",
        mask_geometry_done = FEATURES_DIR / "{experiment}" / "mask_geometry" / "mask_geometry_metrics.csv.validated",
        curvature = FEATURES_DIR / "{experiment}" / "curvature_metrics" / "curvature_metrics.csv",
        curvature_done = FEATURES_DIR / "{experiment}" / "curvature_metrics" / "curvature_metrics.csv.validated",
        pose_kinematics = FEATURES_DIR / "{experiment}" / "pose_kinematics" / "pose_kinematics_metrics.csv",
        pose_kinematics_done = FEATURES_DIR / "{experiment}" / "pose_kinematics" / "pose_kinematics_metrics.csv.validated",
        fraction_alive = FEATURES_DIR / "{experiment}" / "fraction_alive" / "fraction_alive.csv",
        fraction_alive_done = FEATURES_DIR / "{experiment}" / "fraction_alive" / "fraction_alive.csv.validated",
        stage_predictions = FEATURES_DIR / "{experiment}" / "stage_predictions" / "stage_predictions.csv",
        stage_predictions_done = FEATURES_DIR / "{experiment}" / "stage_predictions" / "stage_predictions.csv.validated",
        plate_metadata = EXPERIMENT_METADATA_DIR / "{experiment}" / "plate_metadata.csv",
    output:
        csv = FEATURES_DIR / "{experiment}" / "consolidated" / "consolidated_snip_features.csv",
        done = FEATURES_DIR / "{experiment}" / "consolidated" / "consolidated_snip_features.csv.validated",
        schema = FEATURES_DIR / "{experiment}" / "consolidated" / "consolidated_snip_features.schema.json",
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.feature_extraction.entrypoints.consolidate_features \
          --segmentation-tracking "{input.segmentation_tracking}" \
          --frame-contract "{input.frame_contract}" \
          --mask-geometry "{input.mask_geometry}" \
          --curvature-metrics "{input.curvature}" \
          --pose-kinematics "{input.pose_kinematics}" \
          --fraction-alive "{input.fraction_alive}" \
          --stage-predictions "{input.stage_predictions}" \
          --plate-metadata "{input.plate_metadata}" \
          --output-csv "{output.csv}"
        """


rule feature_extraction_complete:
    input:
        expand(
            FEATURES_DIR / "{exp}" / "consolidated" / "consolidated_snip_features.csv.validated",
            exp=EXPERIMENTS
        )
        + expand(
            FEATURES_DIR / "{exp}" / "stage_predictions" / "stage_predictions.csv.validated",
            exp=EXPERIMENTS
        )
        + expand(
            AUXILIARY_MASKS_DIR / "{exp}" / "contracts" / ".auxiliary_masks.validated",
            exp=EXPERIMENTS
        )

