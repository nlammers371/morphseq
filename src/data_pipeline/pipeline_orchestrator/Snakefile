rule materialize_stitched_images_yx1:
    input:
        raw_images_dir = RAW_IMAGES_DIR / "YX1" / "{experiment}",
        mapping_csv = EXPERIMENT_METADATA_DIR / "{experiment}" / "series_well_mapping.csv",
        scope_csv = EXPERIMENT_METADATA_DIR / "{experiment}" / "scope_metadata_mapped.csv",
    output:
        stitched_index = EXPERIMENT_METADATA_DIR / "{experiment}" / "stitched_image_index.csv",
        done = BUILT_IMAGE_DATA_DIR / "{experiment}" / ".materialize_stitched_images.done"
    params:
        experiment_id = "{experiment}",
        selected_wells = lambda wc: ",".join(experiment_well_ids(wc.experiment)),
        device = lambda wc: str(config.get("image_building", {}).get("device", "cuda")),
        overwrite = lambda wc: int(bool(config.get("image_building", {}).get("overwrite", False))),
        z_buffer = lambda wc: int(bool(config.get("image_building", {}).get("yx1", {}).get("z_buffer", False))),
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.pipeline_orchestrator.tasks materialize-stitched \
          --experiment "{params.experiment_id}" \
          --microscope "YX1" \
          --raw-images-dir "{input.raw_images_dir}" \
          --scope-csv "{input.scope_csv}" \
          --mapping-csv "{input.mapping_csv}" \
          --output-root "{BUILT_IMAGE_DATA_DIR}" \
          --output-stitched-index-csv "{output.stitched_index}" \
          --selected-wells "{params.selected_wells}" \
          --output-image-extension "jpg" \
          --device-preference "{params.device}" \
          --overwrite "{params.overwrite}" \
          --done-flag "{output.done}"
        """


rule build_frame_contract:
    input:
        stitched_index = EXPERIMENT_METADATA_DIR / "{experiment}" / "stitched_image_index.csv",
        mapped_scope = EXPERIMENT_METADATA_DIR / "{experiment}" / "scope_metadata_mapped.csv",
    output:
        contract = EXPERIMENT_METADATA_DIR / "{experiment}" / "frame_contract.csv",
        validated = EXPERIMENT_METADATA_DIR / "{experiment}" / ".frame_contract.validated",
    params:
        channel_id = lambda wildcards: str(config.get("segmentation_and_tracking", {}).get("channel_id", "BF")),
    shell:
        """
                PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.metadata_ingest.frame_contract.build_frame_contract \
                    --stitched-index-csv "{input.stitched_index}" \
                    --scope-metadata-csv "{input.mapped_scope}" \
                    --output-csv "{output.contract}"
                echo "ok" > "{output.validated}"
        """


checkpoint discover_wells:
    input:
        contract = EXPERIMENT_METADATA_DIR / "{experiment}" / "frame_contract.csv",
        validated = EXPERIMENT_METADATA_DIR / "{experiment}" / ".frame_contract.validated",
    output:
        wells_txt = EXPERIMENT_METADATA_DIR / "{experiment}" / "wells.txt"
    params:
        selected_wells = lambda wc: ",".join(experiment_well_ids(wc.experiment)),
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" << 'EOF'
from pathlib import Path
import pandas as pd

contract = Path("{input.contract}")
selected_csv = "{params.selected_wells}".strip()
if selected_csv:
    wells = sorted({{part.strip() for part in selected_csv.split(",") if part.strip()}})
else:
    df = pd.read_csv(contract)
    wells = sorted(set(df["well_id"].astype(str).tolist()))

out = Path("{output.wells_txt}")
out.parent.mkdir(parents=True, exist_ok=True)
out.write_text("\\n".join(wells) + "\\n")
EOF
        """


def wells_for_experiment(wildcards):
    ck = checkpoints.discover_wells.get(experiment=wildcards.experiment)
    p = ck.output.wells_txt
    with open(p, "r", encoding="utf-8") as f:
        return [ln.strip() for ln in f if ln.strip()]


