"""MorphSeq Snakemake workflow for metadata alignment and frame contracts."""

from pathlib import Path
import sys

configfile: "src/data_pipeline/pipeline_orchestrator/config.yaml"

WORKFLOW_DIR = Path(workflow.basedir)
PROJECT_ROOT = WORKFLOW_DIR.parent.parent.parent
SRC_ROOT = PROJECT_ROOT / "src"
if str(SRC_ROOT) not in sys.path:
    sys.path.insert(0, str(SRC_ROOT))

from data_pipeline.pipeline_orchestrator.targets import (  # noqa: E402
    get_experiments,
    get_experiment_microscopes,
    get_selected_wells,
)

PYTHON_EXE = config.get(
    "python_executable",
    "/net/trapnell/vol1/home/mdcolon/software/miniconda3/envs/segmentation_grounded_sam/bin/python",
)

configured_data_root = Path(config.get("data_root", "data_pipeline_output"))
DATA_ROOT = configured_data_root if configured_data_root.is_absolute() else PROJECT_ROOT / configured_data_root
INPUTS_DIR = DATA_ROOT / "inputs"
configured_plate_root = Path(config.get("inputs", {}).get("plate_metadata_dir", "inputs/plate_metadata"))
configured_raw_root = Path(config.get("inputs", {}).get("raw_image_data_dir", "inputs/raw_image_data"))
PLATE_METADATA_DIR = configured_plate_root if configured_plate_root.is_absolute() else DATA_ROOT / configured_plate_root
RAW_IMAGES_DIR = configured_raw_root if configured_raw_root.is_absolute() else DATA_ROOT / configured_raw_root

EXPERIMENT_METADATA_DIR = DATA_ROOT / "experiment_metadata"
BUILT_IMAGE_DATA_DIR = DATA_ROOT / "built_image_data"

EXPERIMENTS = get_experiments(config)
EXPERIMENT_MICROSCOPES = get_experiment_microscopes(config)


def microscope_for_experiment(experiment: str) -> str:
    return EXPERIMENT_MICROSCOPES[experiment]


def selected_wells_for_experiment(experiment: str) -> list[str]:
    return get_selected_wells(config, experiment)


print(f"Project root: {PROJECT_ROOT}")
print(f"Data root: {DATA_ROOT}")
print(f"Experiments: {EXPERIMENTS}")
print(f"Experiment microscopes: {EXPERIMENT_MICROSCOPES}")


rule all:
    """Default target: complete smoke pipeline for metadata + frame contracts."""
    input:
        expand(EXPERIMENT_METADATA_DIR / "{exp}" / ".frame_manifest.validated", exp=EXPERIMENTS)


rule metadata_alignment_complete:
    """Run metadata alignment for all configured experiments."""
    input:
        expand(EXPERIMENT_METADATA_DIR / "{exp}" / "scope_and_plate_metadata.csv", exp=EXPERIMENTS)


rule frame_contracts_complete:
    """Run stitched-index and frame-manifest contract generation for all experiments."""
    input:
        expand(EXPERIMENT_METADATA_DIR / "{exp}" / ".frame_manifest.validated", exp=EXPERIMENTS)


include: "rules/metadata_alignment.smk"
include: "rules/frame_contracts.smk"
