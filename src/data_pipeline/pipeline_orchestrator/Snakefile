# Snip processing (per well, consumes segmentation_tracking only)
# ============================================================================

rule run_snip_processing_per_well:
    input:
        seg = SEGMENTATION_DIR / "{experiment}" / "per_well" / "{well_id}" / "contracts" / "segmentation_tracking.csv",
        seg_done = SEGMENTATION_DIR / "{experiment}" / "per_well" / "{well_id}" / "contracts" / ".segmentation_tracking.validated",
    output:
        manifest = PROCESSED_SNIPS_DIR / "{experiment}" / "per_well" / "{well_id}" / "contracts" / "snip_manifest.parquet",
        done = PROCESSED_SNIPS_DIR / "{experiment}" / "per_well" / "{well_id}" / "contracts" / ".snip_manifest.validated",
    params:
        out_h = lambda wc: int(config.get("snip_processing", {}).get("output_shape", [576, 256])[0]),
        out_w = lambda wc: int(config.get("snip_processing", {}).get("output_shape", [576, 256])[1]),
        target_um = lambda wc: float(config.get("snip_processing", {}).get("target_pixel_size_um", 7.8)),
        save_raw = lambda wc: int(bool(config.get("snip_processing", {}).get("save_raw_crops", True))),
        write_csv = lambda wc: int(bool(config.get("snip_processing", {}).get("write_manifest_csv", True))),
        bg_n = lambda wc: int(config.get("snip_processing", {}).get("background_n_samples", 100)),
        bg_seed = lambda wc: int(config.get("snip_processing", {}).get("background_seed", 309)),
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.snip_processing.run_from_segmentation_tracking \
          --segmentation-tracking "{input.seg}" \
          --output-root "{DATA_ROOT}" \
          --output-shape {params.out_h} {params.out_w} \
          --target-pixel-size-um {params.target_um} \
          --save-raw-crops {params.save_raw} \
          --write-manifest-csv {params.write_csv} \
          --background-n-samples {params.bg_n} \
          --background-seed {params.bg_seed}
        """


rule merge_snip_manifests:
    input:
        lambda wc: [
            str(PROCESSED_SNIPS_DIR / wc.experiment / "per_well" / w / "contracts" / "snip_manifest.parquet")
            for w in wells_for_experiment(wc)
        ]
    output:
        merged = PROCESSED_SNIPS_DIR / "{experiment}" / "contracts" / "snip_manifest.parquet",
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.snip_processing.pipelines.merge_snip_manifests           --experiment "{wildcards.experiment}"           --output-root "{DATA_ROOT}"           --write-views 1
        """


rule validate_snip_manifest:
    input:
        merged = PROCESSED_SNIPS_DIR / "{experiment}" / "contracts" / "snip_manifest.parquet",
    output:
        done = PROCESSED_SNIPS_DIR / "{experiment}" / "contracts" / ".snip_manifest_merged.validated",
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" {PROJECT_ROOT}/src/data_pipeline/snip_processing/pipelines/validate_snip_manifest.py           --input "{input.merged}"           --output-flag "{output.done}"
        """

