rule generate_auxiliary_masks_well:
    input:
        frame_contract = EXPERIMENT_METADATA_DIR / "{experiment}" / "frame_contract.csv",
        frame_contract_done = EXPERIMENT_METADATA_DIR / "{experiment}" / ".frame_contract.validated",
    output:
        manifest = AUXILIARY_MASKS_DIR / "{experiment}" / "per_well" / "{well_id}" / "contracts" / "auxiliary_masks.csv",
        done = AUXILIARY_MASKS_DIR / "{experiment}" / "per_well" / "{well_id}" / "contracts" / ".auxiliary_masks.validated",
    params:
        model_root = lambda wc: str(MODELS_DIR / "segmentation"),
        batch_size = lambda wc: int(config.get("auxiliary_masks", {}).get("batch_size", 64)),
        num_workers = lambda wc: int(config.get("auxiliary_masks", {}).get("num_workers", 1)),
        overwrite_flag = lambda wc: "--overwrite" if bool(config.get("auxiliary_masks", {}).get("overwrite", False)) else "",
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.auxiliary_masks.materialize_auxiliary_masks \
          --frame-contract "{input.frame_contract}" \
          --output-root "{AUXILIARY_MASKS_DIR}/{wildcards.experiment}/per_well/{wildcards.well_id}" \
          --output-manifest-csv "{output.manifest}" \
          --model-root "{params.model_root}" \
          --well-id "{wildcards.well_id}" \
          --batch-size {params.batch_size} \
          --num-workers {params.num_workers} \
          {params.overwrite_flag}
        """

rule aggregate_auxiliary_masks:
    input:
        manifests=lambda wc: [
            AUXILIARY_MASKS_DIR / wc.experiment / "per_well" / well_id / "contracts" / "auxiliary_masks.csv"
            for well_id in experiment_well_ids(wc.experiment)
        ],
        well_done=lambda wc: [
            AUXILIARY_MASKS_DIR / wc.experiment / "per_well" / well_id / "contracts" / ".auxiliary_masks.validated"
            for well_id in experiment_well_ids(wc.experiment)
        ],
    output:
        manifest = AUXILIARY_MASKS_DIR / "{experiment}" / "contracts" / "auxiliary_masks.csv",
        done = AUXILIARY_MASKS_DIR / "{experiment}" / "contracts" / ".auxiliary_masks.validated",
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.auxiliary_masks.merge_auxiliary_masks \
          --inputs {input.manifests} \
          --output-manifest-csv "{output.manifest}"
        """


