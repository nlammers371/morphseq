rule normalize_plate_metadata:
    """
    Normalize and validate plate layout metadata.

    Reads raw plate layout CSV/Excel, normalizes column names, adds
    experiment_id and well_id, then validates against schema.
    """
    input:
        plate_file = PLATE_METADATA_DIR / "{experiment}_well_metadata.xlsx"
    output:
        normalized_csv = EXPERIMENT_METADATA_DIR / "{experiment}" / "plate_metadata.csv",
        validated = EXPERIMENT_METADATA_DIR / "{experiment}" / ".plate_metadata.validated"
    params:
        experiment_id = "{experiment}"
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.pipeline_orchestrator.tasks normalize-plate \
          --input-file "{input.plate_file}" \
          --experiment "{params.experiment_id}" \
          --output-csv "{output.normalized_csv}"
        printf 'ok\n' > "{output.validated}"
        """



rule extract_scope_metadata_yx1:
    """
    Extract scope metadata from YX1 ND2 files.

    Reads ND2 metadata to extract:
    - Micrometers per pixel (calibration)
    - Frame interval (timing)
    - Image dimensions
    - Channel information
    - Series/well mapping
    - Timestamps
    """
    input:
        raw_images_dir = RAW_IMAGES_DIR / "YX1" / "{experiment}"
    output:
        scope_csv = EXPERIMENT_METADATA_DIR / "{experiment}" / "scope_metadata_raw.csv"
    params:
        experiment_id = "{experiment}"
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.metadata_ingest.scope.yx1.extract_scope_metadata \
          --raw-yx1-experiment-dir "{input.raw_images_dir}" \
          --experiment-id "{params.experiment_id}" \
          --output-csv "{output.scope_csv}"
        """


rule extract_scope_metadata_keyence:
    """
    Extract scope metadata from Keyence raw image files.

    Reads TIFF headers to extract:
    - Micrometers per pixel (calibration)
    - Frame interval (timing)
    - Image dimensions
    - Channel information
    - Timestamps
    """
    input:
        raw_images_dir = RAW_IMAGES_DIR / "Keyence" / "{experiment}"
    output:
        scope_csv = EXPERIMENT_METADATA_DIR / "{experiment}" / "scope_metadata_raw.csv"
    params:
        experiment_id = "{experiment}"
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.metadata_ingest.scope.keyence.extract_scope_metadata \
          --raw-keyence-experiment-dir "{input.raw_images_dir}" \
          --experiment-id "{params.experiment_id}" \
          --output-csv "{output.scope_csv}"
        """


rule map_series_to_wells_yx1:
    """
    Physical YX1 series-to-well mapping (ND2 stage positions + reference XY).
    Does not depend on plate metadata.
    """
    input:
        raw_images_dir = RAW_IMAGES_DIR / "YX1" / "{experiment}"
    output:
        mapping_csv = EXPERIMENT_METADATA_DIR / "{experiment}" / "series_well_mapping.csv",
        provenance_json = EXPERIMENT_METADATA_DIR / "{experiment}" / "series_well_mapping.provenance.json"
    params:
        experiment_id = "{experiment}"
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.metadata_ingest.scope.yx1.map_series_to_wells \
          --raw-yx1-experiment-dir "{input.raw_images_dir}" \
          --experiment-id "{params.experiment_id}" \
          --use-xy-reference \
          --output-mapping-csv "{output.mapping_csv}" \
          --output-provenance-json "{output.provenance_json}"
        """


rule apply_series_mapping_yx1:
    """
    Apply series mapping to raw scope metadata to produce canonical well_index/well_id/image_id.
    """
    input:
        scope_csv = EXPERIMENT_METADATA_DIR / "{experiment}" / "scope_metadata_raw.csv",
        mapping_csv = EXPERIMENT_METADATA_DIR / "{experiment}" / "series_well_mapping.csv"
    output:
        mapped_csv = EXPERIMENT_METADATA_DIR / "{experiment}" / "scope_metadata_mapped.csv",
        validated = EXPERIMENT_METADATA_DIR / "{experiment}" / ".scope_metadata_mapped.validated"
    shell:
        """
        PYTHONPATH="{PROJECT_ROOT}:{PROJECT_ROOT}/src" "{PYTHON}" -m data_pipeline.metadata_ingest.scope.shared.apply_series_mapping \
          --scope-metadata-csv "{input.scope_csv}" \
          --series-well-mapping-csv "{input.mapping_csv}" \
          --output-scope-metadata-mapped-csv "{output.mapped_csv}" \
          --experiment-id "{wildcards.experiment}"
        echo "ok" > "{output.validated}"
        """

